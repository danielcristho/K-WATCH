[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=<your_pem_file>
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

[masters]
k8s-master ansible_host= private_ip=

[workers]
k8s-worker ansible_host= private_ip=
k8s-worker-2 ansible_host= private_ip=
k8s-siem ansible_host= private_ip=

[k8s_cluster:children]
masters
workers
